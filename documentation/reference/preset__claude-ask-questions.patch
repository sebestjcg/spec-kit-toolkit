+schema_version: "1.0"
+
+preset:
+  id: "claude-ask-questions"
+  name: "Claude AskUserQuestion"
+  version: "1.0.0"
+  description: "Upgrades /speckit.clarify and /speckit.checklist on Claude Code from Markdown-table prompts to the native AskUserQuestion picker, with a recommended option and reasoning on every question."
+  author: "0xrafasec"
+  repository: "https://github.com/0xrafasec/spec-kit-preset-claude-ask-questions"
+  license: "MIT"
+
+requires:
+  speckit_version: ">=0.6.0"
+
+provides:
+  templates:
+    - type: "command"
+      name: "speckit.clarify"
+      file: "commands/speckit.clarify.md"
+      description: "Clarify command using AskUserQuestion for multiple-choice options"
+      replaces: "speckit.clarify"
+
+    - type: "command"
+      name: "speckit.checklist"
+      file: "commands/speckit.checklist.md"
+      description: "Checklist command using AskUserQuestion for multiple-choice options"
+      replaces: "speckit.checklist"
+
+tags:
+  - "claude"
+  - "ask-user-question"
+  - "clarify"
+  - "checklist"
